COMPOSE_PROJECT_NAME=ash-code
# Copy to .env and fill in the providers you use.
# ash-code does not host any LLM; every provider is consumed as an external API.

# --- harness selection ---
# Which provider plugin to load at startup. Maps to a file under providers/<name>.toml
# or a built-in plugin of the same name.
ASH_LLM_PROVIDER=anthropic
# Optional model override. If blank, the value from providers/<name>.toml is used.
ASH_LLM_MODEL=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- OpenAI-compatible ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- External vLLM (OpenAI-compatible) ---
VLLM_BASE_URL=
VLLM_API_KEY=

# --- External Ollama ---
OLLAMA_BASE_URL=
