COMPOSE_PROJECT_NAME=ash-code
# Copy to .env and fill in the providers you use.
# ash-code does not host any LLM; every provider is consumed as an external API.

# --- harness selection ---
# Which provider plugin to load at startup. Maps to a file under providers/<name>.toml
# or a built-in plugin of the same name.
ASH_LLM_PROVIDER=anthropic
# Optional model override. If blank, the value from providers/<name>.toml is used.
ASH_LLM_MODEL=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- OpenAI-compatible ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- External vLLM (OpenAI-compatible) ---
VLLM_BASE_URL=
VLLM_API_KEY=

# --- External Ollama ---
OLLAMA_BASE_URL=

# --- Session storage (M9.1) ---
# postgres (default) | memory
ASH_SESSION_STORE=postgres
# Connection string. The default value targets the local-db compose
# service `ash-postgres` (started with: docker compose --profile local-db up -d).
# To use an external managed database (RDS, Supabase, Cloud SQL, …),
# set this to the managed URL and do NOT start the local-db profile.
ASH_POSTGRES_URL=postgres://ash:ash@ash-postgres:5432/ashcode
ASH_POSTGRES_POOL_SIZE=8

# Local dev postgres credentials (only consumed by the ash-postgres
# compose service). Override these if you want a different password.
POSTGRES_USER=ash
POSTGRES_PASSWORD=ash
POSTGRES_DB=ashcode
# Host port for the dev postgres. Useful when running integration tests
# from your host: psql -h localhost -p 5432 -U ash -d ashcode
POSTGRES_HOST_PORT=5432
